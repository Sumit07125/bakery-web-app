<%- include('include/admin_header') %>

<style>
  .admin-bills-page { padding: 2rem 0; }
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .page-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin: 0;
  }
  .stats-bar {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .stat-chip {
    background: white;
    border-radius: 12px;
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1.5px solid #e5e7eb;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .bill-card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    margin-bottom: 1.5rem;
    overflow: hidden;
    border: 1px solid #f3f4f6;
  }
  .bill-card-header {
    background: #1e293b;
    color: white;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .bill-card-header .bill-id { font-size: 1rem; font-weight: 700; }
  .bill-card-header .customer { color: #d97706; font-weight: 600; }
  .bill-card-header .bill-date { font-size: 0.8rem; opacity: 0.6; }
  .bill-card-body { padding: 1.5rem; }

  .status-form {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #f3f4f6;
  }
  .status-select {
    border-radius: 10px;
    border: 1.5px solid #e5e7eb;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    color: #374151;
    background: #f9fafb;
    flex: 1;
    min-width: 200px;
  }
  .status-select:focus { border-color: #d97706; outline: none; box-shadow: 0 0 0 3px rgba(217,119,6,0.15); }
  .btn-update {
    background: linear-gradient(135deg, #b45309, #d97706);
    border: none;
    color: white;
    border-radius: 10px;
    padding: 0.5rem 1.25rem;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s;
    white-space: nowrap;
  }
  .btn-update:hover { background: linear-gradient(135deg, #92400e, #b45309); transform: translateY(-1px); }
  .total-amount { font-weight: 700; color: #b45309; font-size: 1.05rem; }

  .status-badge {
    font-size: 0.8rem;
    padding: 0.35rem 0.8rem;
    border-radius: 20px;
    font-weight: 600;
  }
  .badge-received   { background: #dbeafe; color: #1d4ed8; }
  .badge-baking     { background: #fef3c7; color: #92400e; }
  .badge-delivery   { background: #d1fae5; color: #065f46; }
  .badge-delivered  { background: #dcfce7; color: #14532d; }
</style>

<div class="container admin-bills-page">
  <div class="page-header">
    <h2><i class="bi bi-list-check me-2"></i>All Orders</h2>
    <span class="text-muted"><%= bills.length %> total order<%= bills.length !== 1 ? 's' : '' %></span>
  </div>

  <% if (bills.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-inbox fs-1 d-block mb-3"></i>
      No orders have been placed yet.
    </div>
  <% } %>

  <% bills.forEach(bill => {
    const os = bill.order_status || 'Order Received';
    let badgeClass = 'badge-received';
    if (os === 'Baking in Progress') badgeClass = 'badge-baking';
    else if (os === 'Out for Delivery') badgeClass = 'badge-delivery';
    else if (os === 'Delivered') badgeClass = 'badge-delivered';
  %>
  <div class="bill-card">
    <div class="bill-card-header">
      <div>
        <span class="bill-id"><i class="bi bi-receipt me-1"></i>Order #<%= bill.bill_id %></span>
        <span class="ms-3 customer"><i class="bi bi-person me-1"></i><%= bill.username %></span>
      </div>
      <div class="d-flex align-items-center gap-2">
        <span class="status-badge <%= badgeClass %>"><%= os %></span>
        <span class="bill-date"><%= bill.bill_date.toDateString() %></span>
      </div>
    </div>
    <div class="bill-card-body">
      <div class="row">
        <div class="col-md-8">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr><th>Item</th><th>Qty</th></tr>
            </thead>
            <tbody>
              <% if (bill.item1) { %><tr><td><%= bill.item1 %></td><td><span class="badge bg-secondary"><%= bill.q1 %></span></td></tr><% } %>
              <% if (bill.item2) { %><tr><td><%= bill.item2 %></td><td><span class="badge bg-secondary"><%= bill.q2 %></span></td></tr><% } %>
              <% if (bill.item3) { %><tr><td><%= bill.item3 %></td><td><span class="badge bg-secondary"><%= bill.q3 %></span></td></tr><% } %>
            </tbody>
          </table>
          <p class="total-amount mt-2"><i class="bi bi-currency-rupee"></i><%= bill.total_amount %></p>
        </div>
        <div class="col-md-4">
          <form class="status-form" action="/update-bill/<%= bill.bill_id %>" method="POST">
            <select name="order_status" class="status-select">
              <option value="Order Received"    <%= os === 'Order Received'    ? 'selected' : '' %>>📋 Order Received</option>
              <option value="Baking in Progress" <%= os === 'Baking in Progress' ? 'selected' : '' %>>🧑‍🍳 Baking in Progress</option>
              <option value="Out for Delivery"  <%= os === 'Out for Delivery'  ? 'selected' : '' %>>🚚 Out for Delivery</option>
              <option value="Delivered"         <%= os === 'Delivered'         ? 'selected' : '' %>>✅ Delivered</option>
            </select>
            <button type="submit" class="btn-update">Update</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
</div>

<%- include('include/admin_footer') %>