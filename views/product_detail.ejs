<%- include('include/header') %>

<style>
  .product-detail-wrapper { padding: 3rem 0; }
  .detail-card {
    background: white;
    border-radius: 24px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .detail-img-col { padding: 0; }
  .detail-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: 24px 0 0 24px;
  }
  @media(max-width:768px) {
    .detail-img { height: 260px; border-radius: 24px 24px 0 0; }
    .detail-card .row { flex-direction: column; }
  }
  .detail-info { padding: 2.5rem; }
  .category-badge {
    display: inline-block;
    background: #fff7ed;
    color: #b45309;
    border: 1.5px solid #fed7aa;
    border-radius: 20px;
    padding: 0.25rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .product-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }
  .product-price {
    font-size: 1.8rem;
    font-weight: 700;
    color: #b45309;
    margin-bottom: 1rem;
  }
  .product-description {
    color: #6b7280;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .stars-display { color: #f59e0b; font-size: 1.2rem; }
  .rating-text { font-size: 0.9rem; color: #6b7280; }
  .btn-add-cart {
    background: linear-gradient(135deg, #b45309, #d97706);
    border: none;
    color: white;
    border-radius: 12px;
    padding: 0.85rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-add-cart:hover {
    background: linear-gradient(135deg, #92400e, #b45309);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(180,83,9,0.35);
    color: white;
  }

  /* Reviews Section */
  .reviews-section { margin-top: 2rem; }
  .section-heading {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: #1f2937;
  }
  .review-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    border-left: 4px solid #d97706;
  }
  .reviewer-name { font-weight: 700; color: #1f2937; }
  .review-date { font-size: 0.8rem; color: #9ca3af; }
  .review-text { color: #4b5563; margin-top: 0.5rem; line-height: 1.6; }
  .review-stars { color: #f59e0b; font-size: 1rem; }

  /* Leave Review Form */
  .leave-review-card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    padding: 2rem;
    margin-top: 1.5rem;
  }
  .star-rating { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
  .star-rating input { display: none; }
  .star-rating label {
    font-size: 2rem;
    color: #d1d5db;
    cursor: pointer;
    transition: color 0.2s;
  }
  .star-rating input:checked ~ label,
  .star-rating label:hover,
  .star-rating label:hover ~ label { color: #f59e0b; }
  .star-rating { flex-direction: row-reverse; }
  .star-rating label:hover, .star-rating label:hover ~ label { color: #f59e0b; }
  .star-rating input:checked + label, .star-rating input:checked ~ label { color: #f59e0b; }
</style>

<div class="container product-detail-wrapper">
  <div class="detail-card">
    <div class="row g-0">
      <div class="col-md-5 detail-img-col">
        <img src="<%= product.img_url %>" alt="<%= product.product_name %>" class="detail-img">
      </div>
      <div class="col-md-7">
        <div class="detail-info">
          <span class="category-badge"><%= product.category || 'Product' %></span>
          <h1 class="product-title"><%= product.product_name %></h1>

          <div class="d-flex align-items-center gap-2 mb-3">
            <span class="stars-display">
              <% for(let i=1; i<=5; i++) { %>
                <% if(i <= Math.round(product.avg_rating)) { %><i class="bi bi-star-fill"></i><% } else { %><i class="bi bi-star"></i><% } %>
              <% } %>
            </span>
            <span class="rating-text">
              <strong><%= product.avg_rating > 0 ? product.avg_rating : 'No' %></strong>
              (<%= product.review_count %> review<%= product.review_count !== 1 ? 's' : '' %>)
            </span>
          </div>

          <p class="product-price"><i class="bi bi-currency-rupee"></i><%= product.price %></p>

          <p class="product-description">
            <%= product.description || 'A delicious product from our bakery, made with love and the finest ingredients.' %>
          </p>

          <div class="d-flex gap-3 flex-wrap">
            <% if (locals.user) { %>
              <a href="/addtocart/<%= product.product_id %>" class="btn-add-cart">
                <i class="bi bi-cart-plus"></i> Add to Cart
              </a>
            <% } else { %>
              <a href="/user_login" class="btn-add-cart">
                <i class="bi bi-box-arrow-in-right"></i> Login to Add
              </a>
            <% } %>
            <a href="/" class="btn btn-outline-secondary rounded-pill px-4 text-nowrap d-inline-flex align-items-center gap-2">
              <i class="bi bi-arrow-left"></i> Back to Shop
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section">
    <div class="row">
      <div class="col-lg-7">
        <h3 class="section-heading"><i class="bi bi-chat-quote me-2"></i>Customer Reviews</h3>
        <% if (reviews && reviews.length > 0) { %>
          <% reviews.forEach(review => { %>
            <div class="review-card">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <span class="reviewer-name"><i class="bi bi-person-circle me-1 text-muted"></i><%= review.reviewer_name %></span>
                  <div class="review-stars">
                    <% for(let i=1; i<=5; i++) { %>
                      <% if(i <= review.rating) { %><i class="bi bi-star-fill"></i><% } else { %><i class="bi bi-star"></i><% } %>
                    <% } %>
                  </div>
                </div>
                <span class="review-date"><%= new Date(review.created_at).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span>
              </div>
              <% if (review.review_text) { %>
                <p class="review-text"><%= review.review_text %></p>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="text-center py-4 text-muted" style="background:white; border-radius:16px;">
            <i class="bi bi-chat-dots fs-2 d-block mb-2"></i>
            Be the first to review this product!
          </div>
        <% } %>
      </div>

      <!-- Leave a Review -->
      <div class="col-lg-5">
        <h3 class="section-heading"><i class="bi bi-pencil-square me-2"></i>Your Review</h3>
        <% if (!locals.user) { %>
          <div class="leave-review-card text-center">
            <i class="bi bi-lock fs-2 text-muted d-block mb-2"></i>
            <p class="text-muted">Please <a href="/user_login" class="text-primary fw-bold">log in</a> to leave a review.</p>
          </div>
        <% } else if (!hasPurchased) { %>
          <div class="leave-review-card text-center">
            <i class="bi bi-bag fs-2 text-muted d-block mb-2"></i>
            <p class="text-muted">You need to purchase this item before leaving a review.</p>
          </div>
        <% } else { %>
          <div class="leave-review-card">
            <% if (myReview) { %>
              <div class="alert alert-success border-0 rounded-3 mb-3">
                <div class="d-flex justify-content-between align-items-center">
                  <span><i class="bi bi-check-circle me-1"></i> You've already reviewed this product.</span>
                  <form action="/product/<%= product.product_id %>/review/delete" method="POST" style="margin:0;">
                    <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1"><i class="bi bi-trash"></i> Delete</button>
                  </form>
                </div>
              </div>
            <% } %>
            <form action="/product/<%= product.product_id %>/review" method="POST">
              <div class="mb-3">
                <label class="form-label fw-semibold">Your Rating</label>
                <div class="star-rating">
                  <% for(let i=5; i>=1; i--) { %>
                    <input type="radio" id="star<%= i %>" name="rating" value="<%= i %>" <%= myReview && myReview.rating == i ? 'checked' : '' %>>
                    <label for="star<%= i %>" title="<%= i %> stars"><i class="bi bi-star-fill"></i></label>
                  <% } %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold">Your Review (optional)</label>
                <textarea name="review_text" class="form-control" rows="4" placeholder="Tell others what you think..."><%= myReview ? myReview.review_text : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary rounded-pill px-4 w-100">
                <i class="bi bi-send me-1"></i> <%= myReview ? 'Update Review' : 'Submit Review' %>
              </button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<% if (locals.toast) { %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    Swal.fire({
      toast: true, position: 'top-end', showConfirmButton: false, timer: 3000,
      icon: '<%= locals.toast %>',
      title: '<%= decodeURIComponent(locals.msg || '') %>'
    });
  });
</script>
<% } %>

<%- include('include/footer') %>