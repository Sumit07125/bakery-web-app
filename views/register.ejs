<%- include('include/header') %>

<style>
  .auth-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: var(--bg-color);
  }
  .auth-card {
    width: 100%;
    max-width: 520px;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    overflow: hidden;
    animation: slideUp 0.5s ease;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .auth-header {
    background: linear-gradient(135deg, #b45309, #d97706, #f59e0b);
    padding: 2rem;
    text-align: center;
    color: white;
  }
  .auth-header .logo-icon { font-size: 2.5rem; margin-bottom: 0.25rem; }
  .auth-header h2 { font-family: 'Playfair Display', serif; font-size: 1.6rem; margin: 0; }
  .auth-header p { margin: 0.25rem 0 0; font-size: 0.85rem; opacity: 0.9; }
  .auth-body { padding: 2rem; }
  .form-control {
    border-radius: 12px !important;
    border: 1.5px solid #e5e7eb;
    padding: 0.7rem 1rem;
    font-size: 0.9rem;
    transition: all 0.3s;
  }
  .form-control:focus { border-color: #d97706; box-shadow: 0 0 0 3px rgba(217,119,6,0.15); }
  .input-group-text {
    background: #fff7ed;
    border: 1.5px solid #e5e7eb;
    border-right: none;
    border-radius: 12px 0 0 12px !important;
    color: #d97706;
  }
  .input-group .form-control { border-left: none; border-radius: 0 12px 12px 0 !important; }
  .btn-register {
    background: linear-gradient(135deg, #b45309, #d97706);
    border: none;
    color: white;
    border-radius: 12px;
    padding: 0.85rem;
    font-size: 1rem;
    font-weight: 600;
    width: 100%;
    transition: all 0.3s;
  }
  .btn-register:hover {
    background: linear-gradient(135deg, #92400e, #b45309);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(180,83,9,0.35);
    color: white;
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .auth-footer-link { text-align: center; margin-top: 1rem; font-size: 0.9rem; color: #6b7280; }
  .auth-footer-link a { color: #d97706; font-weight: 600; text-decoration: none; }
  .auth-footer-link a:hover { text-decoration: underline; }
</style>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <div class="logo-icon">🍰</div>
      <h2>Create Your Account</h2>
      <p>Join thousands of happy bakery customers</p>
    </div>
    <div class="auth-body">
      <form action="/register" method="POST">
        <div class="form-row mb-3">
          <div>
            <label class="form-label fw-semibold text-muted small">Full Name</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-person"></i></span>
              <input type="text" class="form-control" name="name" placeholder="Your name" required>
            </div>
          </div>
          <div>
            <label class="form-label fw-semibold text-muted small">Age</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-calendar"></i></span>
              <input type="number" class="form-control" name="age" placeholder="Age" min="1" required>
            </div>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold text-muted small">Address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
            <input type="text" class="form-control" name="address" placeholder="Your delivery address" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold text-muted small">Mobile Number</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-phone"></i></span>
            <input type="tel" class="form-control" name="phone_number" placeholder="10-digit number" pattern="[0-9]{10}" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold text-muted small">Email Address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" class="form-control" name="email" placeholder="you@example.com" required>
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold text-muted small">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" class="form-control" name="passward" placeholder="Create a password" required>
          </div>
        </div>
        <button type="submit" class="btn-register">
          <i class="bi bi-person-plus me-2"></i> Create Account
        </button>
      </form>
      <div class="auth-footer-link mt-3">
        Already have an account? <a href="/user_login">Sign in</a>
      </div>
    </div>
  </div>
</div>

<%- include('include/footer') %>
