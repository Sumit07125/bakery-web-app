<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>The Cake Shop</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400&family=Great+Vibes&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@700&family=Open+Sans:wght@300;400&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #d97706; /* Amber 600 */
      --primary-hover: #b45309; /* Amber 700 */
      --secondary-color: #4b5563; /* Gray 600 */
      --bg-color: #fcfaf8;
      --card-bg: #ffffff;
      --text-main: #1f2937; /* Gray 800 */
      --text-muted: #6b7280; /* Gray 500 */
      --transition-speed: 0.3s;
    }
    body {
      font-family: 'Poppins', 'Open Sans', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      background-image: url('https://images.unsplash.com/photo-1588072432836-e10032774350');
      background-repeat: repeat;
    }
    .navbar {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
      padding: 1rem 2rem;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar-brand {
      font-family: 'Great Vibes', cursive;
      font-weight: 700;
      font-size: 2.5rem;
      background: linear-gradient(to right, #b45309, #d97706);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      transition: transform var(--transition-speed);
    }
    .navbar-brand:hover {
      transform: scale(1.05);
    }
    .search-form .input-group {
      border: 1px solid #e5e7eb;
      transition: all var(--transition-speed);
    }
    .search-form .input-group:focus-within {
      box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.2);
      border-color: var(--primary-color);
    }
    .search-form .form-control:focus {
      box-shadow: none;
    }
    .btn {
      border-radius: 50px; /* Pill shape */
      font-weight: 500;
      transition: all var(--transition-speed) ease;
    }
    .btn-primary {
      background-color: var(--primary-color);
      border-color: var(--primary-color);
    }
    .btn-primary:hover {
      background-color: var(--primary-hover);
      border-color: var(--primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 4px 6px rgba(217, 119, 6, 0.25);
    }
    .btn-outline-primary {
      color: var(--primary-color);
      border-color: var(--primary-color);
    }
    .btn-outline-primary:hover {
      background-color: var(--primary-color);
      color: white;
      transform: translateY(-2px);
    }
    .btn-outline-secondary:hover {
      transform: translateY(-2px);
    }
    .carousel-item {
      height: 60vh;
      min-height: 400px;
      position: relative;
    }
    .carousel-item img {
      height: 100%;
      width: 100%;
      object-fit: cover;
      filter: brightness(0.85);
    }
    .carousel-caption {
      bottom: 20%;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(8px);
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      transform: translateY(20px);
      opacity: 0;
      animation: fadeInUp 0.8s forwards;
    }
    @keyframes fadeInUp {
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }
    .carousel-caption h5 {
      color: var(--text-main);
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      margin: 0;
    }
    @media (max-width: 768px) {
      .carousel-item {
        height: 40vh;
      }
      .carousel-caption h5 {
        font-size: 1.5rem;
      }
      .navbar {
        padding: 0.5rem 1rem;
      }
      .navbar-brand {
        font-size: 1.5rem;
      }
      /* Ensure action buttons shrink appropriately */
      .d-flex.flex-row.flex-nowrap.gap-2 {
        gap: 0.25rem !important;
      }
      .d-flex.flex-row.flex-nowrap.gap-2 .btn {
        padding: 0.375rem 0.5rem;
        font-size: 0.8rem;
      }
    }
    .product-card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05), 0 10px 15px rgba(0,0,0,0.025);
      background: linear-gradient(145deg, #fdfaf6, #f0e9e1);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .product-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    }
    .product-card .badge {
      position: absolute;
      top: 15px;
      right: 15px;
      background: linear-gradient(135deg, #fbbf24, #d97706);
      color: white;
      font-family: 'Poppins', sans-serif;
      padding: 0.5em 1em;
      border-radius: 20px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      z-index: 10;
    }
    .product-card .card-img-top {
      border-top-left-radius: 16px;
      border-top-right-radius: 16px;
      object-fit: cover;
      height: 220px;
      transition: transform 0.5s ease;
    }
    .product-card:hover .card-img-top {
      transform: scale(1.05);
    }
    .product-card .card-body {
      padding: 1.5rem;
      z-index: 1;
      background: transparent;
    }
    .product-card .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-main);
    }
    .product-card .card-text {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }
    .product-card .price {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--primary-color);
    }
    .product-card .btn-primary {
      border-radius: 20px;
      padding: 0.5rem 1.5rem;
      font-weight: 600;
      margin-top: 1rem;
    }
    .footer {
      background: #1f2937; /* Gray 800 */
      color: #e5e7eb;
      padding: 4rem 0 2rem;
      margin-top: 3rem;
    }
    .footer h5 {
      font-family: 'Playfair Display', serif;
      color: #fbbf24;
      margin-bottom: 1.5rem;
      font-size: 1.25rem;
    }
    .footer a {
      color: #9ca3af;
      text-decoration: none;
      transition: color var(--transition-speed);
    }
    .footer a:hover {
      color: #fbbf24;
    }
    .footer .list-unstyled li {
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 3rem;
      position: relative;
      color: var(--text-main);
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 3px;
      background: var(--primary-color);
      border-radius: 2px;
    }
  </style>
</head>
<body>
  <%- include('include/navbar') %>

  <!-- Carousel -->
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
      <div class="carousel-item active">
        <img src="https://images.unsplash.com/photo-1563729784474-d77dbb933a9e" class="d-block w-100" alt="...">
        <div class="carousel-caption d-none d-md-block">
          <h5 style="color: #8B4513; font-family: 'Playfair Display', serif;">Baked with love, just for you.</h5>
        </div>
      </div>
      <div class="carousel-item">
        <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff" class="d-block w-100" alt="...">
        <div class="carousel-caption d-none d-md-block">
          <h5 style="color: #8B4513; font-family: 'Playfair Display', serif;">Freshly baked bread, every day.</h5>
        </div>
      </div>
      <div class="carousel-item">
        <img src="https://images.unsplash.com/photo-1558961363-fa8fdf82db35" class="d-block w-100" alt="...">
        <div class="carousel-caption d-none d-md-block">
          <h5 style="color: #8B4513; font-family: 'Playfair Display', serif;">A little slice of heaven.</h5>
        </div>
      </div>
      <div class="carousel-item">
        <img src="https://images.unsplash.com/photo-1555507036-ab1f4038808a" class="d-block w-100" alt="...">
        <div class="carousel-caption d-none d-md-block">
          <h5 style="color: #8B4513; font-family: 'Playfair Display', serif;">Life is short, eat dessert first.</h5>
        </div>
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>

  <!-- Product Grid -->
  <div class="container my-5">
    <h2 class="section-title">Our Products</h2>

    <!-- Category Filter Pills -->
    <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
      <% const cats = ['All', 'Cakes', 'Pastries', 'Sweets', 'Cookies', 'Breads']; %>
      <% const catIcons = {'All':'🍽️','Cakes':'🎂','Pastries':'🥐','Sweets':'🍬','Cookies':'🍪','Breads':'🍞'}; %>
      <% cats.forEach(cat => { %>
        <a href="/?category=<%= cat %>#products-section" 
           class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm <%= (locals.activeCategory || 'All') === cat ? 'btn-primary' : 'btn-outline-secondary' %>" 
           style="font-size: 0.9rem;">
          <%= catIcons[cat] %> <%= cat %>
        </a>
      <% }); %>
    </div>

    <div class="row" id="products-section">
      <% products.forEach((product, index) => { %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
          <div class="product-card h-100">
            <% if (index === 0) { %>
              <span class="badge">Best Seller</span>
            <% } else if (product.product_id % 3 === 0) { %>
              <span class="badge" style="background: linear-gradient(135deg, #34d399, #059669);">Freshly Baked</span>
            <% } %>
            <div class="position-relative overflow-hidden" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
              <img src="<%= product.img_url %>" class="card-img-top w-100" alt="<%= product.name %>" style="height: 220px; object-fit: cover;">
              <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-0 transition-opacity hover-overlay"></div>
            </div>
            <div class="card-body d-flex flex-column p-4">
              <h5 class="card-title text-truncate" title="<%= product.name %>"><%= product.name %></h5>
              <div class="d-flex align-items-center text-warning mb-2" style="font-size: 0.85rem;">
                <% const avgR = Math.round(product.avg_rating || 0); %>
                <% for(let s=1; s<=5; s++) { %>
                  <% if(s <= avgR) { %><i class="bi bi-star-fill"></i><% } else { %><i class="bi bi-star text-muted"></i><% } %>
                <% } %>
                <span class="text-muted ms-2" style="font-family: 'Poppins', sans-serif;">
                  <% if(product.review_count > 0) { %>(<%= product.avg_rating %>)<% } else { %>No reviews<% } %>
                </span>
              </div>
              <p class="card-text text-muted mb-4" style="font-size: 0.9rem; line-height: 1.5; flex-grow: 1;">
                <%= product.description ? (product.description.length > 65 ? product.description.substring(0, 65) + '...' : product.description) : 'A delicious freshly baked treat just for you.' %>
              </p>
              <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-light" style="border-color: rgba(0,0,0,0.05) !important;">
                <span class="price fs-4 fw-bold text-primary mb-0"><small class="text-secondary fs-6 fw-normal me-1">Rs</small><%= product.price %></span>
                <a href="/product/<%= product.product_id %>" class="btn btn-primary rounded-pill px-4 d-flex align-items-center gap-2 shadow-sm transition hover-lift">
                  <i class="bi bi-cart-plus-fill fs-5"></i> Add
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-4 col-md-6">
          <h4 class="mb-4 text-warning" style="font-family: 'Playfair Display', serif;">The Cake Shop</h4>
          <p class="text-secondary">We are a family-owned bakery dedicated to creating the most delicious and beautiful baked goods. All our products are made with love, using only the freshest ingredients.</p>
          <div class="d-flex gap-3 mt-4">
            <a href="#" class="fs-4"><i class="bi bi-facebook"></i></a>
            <a href="#" class="fs-4"><i class="bi bi-instagram"></i></a>
            <a href="#" class="fs-4"><i class="bi bi-twitter"></i></a>
            <a href="#" class="fs-4"><i class="bi bi-youtube"></i></a>
          </div>
        </div>
        
        <div class="col-lg-2 col-md-6">
          <h5 class="mb-4 text-warning">Quick Links</h5>
          <ul class="list-unstyled d-flex flex-column gap-2">
            <li><a href="/">Home</a></li>
            <li><a href="/products">Shop</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        
        <div class="col-lg-3 col-md-6">
          <h5 class="mb-4 text-warning">Contact Us</h5>
          <ul class="list-unstyled d-flex flex-column gap-3 text-secondary">
            <li class="d-flex align-items-center gap-2"><i class="bi bi-envelope text-warning"></i> <a href="mailto:info@thecakeshop.com">info@thecakeshop.com</a></li>
            <li class="d-flex align-items-center gap-2"><i class="bi bi-telephone text-warning"></i> +1 234 567 890</li>
            <li class="d-flex align-items-start gap-2"><i class="bi bi-geo-alt text-warning mt-1"></i> 123 Cake Street,<br>Sweetville, Bakery State</li>
          </ul>
        </div>

        <div class="col-lg-3 col-md-6">
          <h5 class="mb-4 text-warning">Newsletter</h5>
          <p class="text-secondary">Subscribe to get special offers, free giveaways, and deals.</p>
          <form class="mt-3" action="#">
            <div class="input-group mb-3">
              <input type="email" class="form-control bg-transparent text-light border-secondary" placeholder="Email address" required>
              <button class="btn btn-warning px-3" type="submit"><i class="bi bi-send-fill text-dark"></i></button>
            </div>
          </form>
        </div>
      </div>
      
      <hr class="border-secondary my-4">
      
      <div class="row">
        <div class="col-md-6 text-center text-md-start">
          <p class="text-secondary mb-0">&copy; <%= new Date().getFullYear() %> The Cake Shop. All Rights Reserved.</p>
        </div>
        <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
          <p class="text-secondary mb-0">Baked with <i class="bi bi-heart-fill text-danger mx-1"></i> by Swad Dhulekar</p>
        </div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>