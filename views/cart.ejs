<%- include('include/header') %>

<style>
  .cart-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2rem;
  }
  .cart-table th, .cart-table td {
    padding: 1rem;
    border-bottom: 1px solid #eee;
  }
  .cart-table th {
    text-align: left;
    font-weight: 600;
  }
  .cart-table td {
    vertical-align: middle;
  }
  .cart-table img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 10px;
  }
  .quantity-controls a {
    margin: 0 5px;
  }
  .cart-summary {
    background-color: #f8f9fa;
    padding: 2rem;
    border-radius: 15px;
  }
</style>

<div class="container my-5">
  <h2 class="text-center mb-4">Your Shopping Cart</h2>
  <% if (products.length > 0) { %>
    <div class="row">
      <!-- Left Column: Offers and Summary (Now moved to Right on large screens) -->
      <div class="col-lg-4 order-lg-1 mb-4">
        <div class="cart-summary shadow-sm bg-white border" style="border-radius: 16px;">
          <h4 id="offersTitle" class="mb-3 font-weight-bold" style="font-family: 'Playfair Display', serif;">Available Offers</h4>
          <div class="mb-4">
            <div class="form-check mb-2">
              <input class="form-check-input discount-radio" type="radio" name="discountScheme" id="scheme1" value="SCHEME1" data-discount="0.05" <%= titem >= 3 ? '' : 'disabled' %>>
              <label class="form-check-label <%= titem >= 3 ? '' : 'text-muted' %>" for="scheme1">
                <i class="bi bi-tag-fill text-success me-1"></i> 5% Off (Buy 3+ items)
              </label>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input discount-radio" type="radio" name="discountScheme" id="scheme2" value="SCHEME2" data-discount="0.10" <%= total > 2000 ? '' : 'disabled' %>>
              <label class="form-check-label <%= total > 2000 ? '' : 'text-muted' %>" for="scheme2">
                <i class="bi bi-tag-fill text-success me-1"></i> 10% Off (Orders above Rs 2000)
              </label>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input discount-radio" type="radio" name="discountScheme" id="scheme3" value="SCHEME3" data-discount="0.15" <%= titem >= 5 ? '' : 'disabled' %>>
              <label class="form-check-label <%= titem >= 5 ? '' : 'text-muted' %>" for="scheme3">
                <i class="bi bi-tag-fill text-success me-1"></i> 15% Off (Buy 5+ items)
              </label>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input discount-radio" type="radio" name="discountScheme" id="scheme4" value="SCHEME4" data-discount="0.20" <%= total > 5000 ? '' : 'disabled' %>>
              <label class="form-check-label <%= total > 5000 ? '' : 'text-muted' %>" for="scheme4">
                <i class="bi bi-tag-fill text-success me-1"></i> 20% Off (Orders above Rs 5000)
              </label>
            </div>
          </div>

          <h4 class="mb-3 font-weight-bold" style="font-family: 'Playfair Display', serif;">Cart Summary</h4>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Total Items:</span>
            <span class="fw-bold"><%= titem %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Subtotal:</span>
            <span class="fw-bold">Rs <%= total %></span>
          </div>
          <div class="d-flex justify-content-between text-success mb-2" id="discountRow" style="display: none !important;">
            <span>Discount Applied:</span>
            <span class="fw-bold" id="discountAmountStr">- Rs 0</span>
          </div>
          <hr>
          <!-- Payment Method Options -->
          <h5 class="mb-3 font-weight-bold" style="font-family: 'Playfair Display', serif;">Payment Method</h5>
          <div class="mb-4">
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="paymentMethod" id="payOnline" value="online" checked>
              <label class="form-check-label fw-semibold" for="payOnline">
                <i class="bi bi-credit-card text-primary me-1"></i> Online Payment
              </label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="paymentMethod" id="payCOD" value="cod">
              <label class="form-check-label fw-semibold" for="payCOD">
                <i class="bi bi-cash-coin text-success me-1"></i> Cash on Delivery
              </label>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-end mt-3">
            <h5 class="mb-0">Total:</h5>
            <div class="text-end">
              <h6 class="text-muted text-decoration-line-through mb-1" id="originalTotal" style="display: none;">Rs <%= total %></h6>
              <h3 class="text-primary fw-bold mb-0" id="finalTotal">Rs <%= total %></h3>
            </div>
          </div>
          <div class="d-grid gap-2 mt-4">
            <form id="checkoutForm" action="/checkout-cod" method="POST" style="display: none;">
              <!-- Hidden input to pass the selected discount code to the COD backend -->
              <input type="hidden" name="discountCode" id="codDiscountCode" value="NONE">
            </form>
            <button id="rzp-button" class="btn btn-primary rounded-pill py-2 shadow-sm fw-bold">Proceed to Checkout</button>
            <a href="/" class="btn btn-outline-secondary rounded-pill py-2">Continue Shopping</a>
          </div>
        </div>
      </div>

      <!-- Right Column: Cart Table (Now moved to Left on large screens) -->
      <div class="col-lg-8 order-lg-0 mb-4">
        <div class="table-responsive shadow-sm bg-white border" style="border-radius: 16px; padding: 1rem;">
          <table class="cart-table table table-hover mb-0">
            <thead>
              <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(product => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <img src="<%= product.img_url %>" alt="<%= product.product_name %>">
                      <span class="ms-3 fw-bold"><%= product.product_name %></span>
                    </div>
                  </td>
                  <td>Rs <%= product.price %></td>
                  <td>
                    <div class="d-flex align-items-center quantity-controls">
                      <a href="/updatecartminus/<%= product.product_id %>" class="btn btn-sm btn-outline-danger px-2">-</a>
                      <span class="mx-2 fw-bold"><%= product.quantity %></span>
                      <a href="/updatecartplus/<%= product.product_id %>" class="btn btn-sm btn-outline-success px-2">+</a>
                    </div>
                  </td>
                  <td class="fw-bold text-primary">Rs <%= product.price * product.quantity %></td>
                  <td>
                    <a href="/remove_from_cart/<%= product.product_id %>" class="btn btn-sm btn-outline-danger rounded-pill px-3">Remove</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  let baseTotal = <%= total %>;
  let finalCalculatedTotal = baseTotal;
  let currentDiscountCode = "NONE";

  document.querySelectorAll('.discount-radio').forEach(radio => {
    radio.addEventListener('change', function() {
      const discountRate = parseFloat(this.getAttribute('data-discount'));
      currentDiscountCode = this.value;
      
      if (discountRate > 0) {
        const discountAmount = Math.round(baseTotal * discountRate);
        finalCalculatedTotal = baseTotal - discountAmount;
        
        document.getElementById('discountRow').style.setProperty('display', 'flex', 'important');
        document.getElementById('discountAmountStr').innerText = `- Rs ${discountAmount}`;
        document.getElementById('originalTotal').style.display = 'block';
        document.getElementById('finalTotal').innerText = `Rs ${finalCalculatedTotal}`;
      } else {
        finalCalculatedTotal = baseTotal;
        document.getElementById('discountRow').style.setProperty('display', 'none', 'important');
        document.getElementById('originalTotal').style.display = 'none';
        document.getElementById('finalTotal').innerText = `Rs ${finalCalculatedTotal}`;
      }
    });
  });

  // Auto-select the best available discount
  let bestDiscountRadio = null;
  let maxDiscount = 0;
  document.querySelectorAll('.discount-radio').forEach(radio => {
    if (!radio.disabled) {
      const discountRate = parseFloat(radio.getAttribute('data-discount'));
      if (discountRate > maxDiscount) {
        maxDiscount = discountRate;
        bestDiscountRadio = radio;
      }
    }
  });

  if (bestDiscountRadio) {
    bestDiscountRadio.checked = true;
    bestDiscountRadio.dispatchEvent(new Event('change'));

    // Trigger celebration if discount is >= 10%
    if (maxDiscount >= 0.10) {
      const offersTitle = document.getElementById('offersTitle');
      if (offersTitle) {
        offersTitle.innerHTML = `🎉 Congratulations! You got ${maxDiscount * 100}% discount!`;
        offersTitle.classList.add('text-success');
      }

      // Confetti logic
      var duration = 3 * 1000;
      var animationEnd = Date.now() + duration;
      var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 1000 };

      function randomInRange(min, max) {
        return Math.random() * (max - min) + min;
      }

      var interval = setInterval(function() {
        var timeLeft = animationEnd - Date.now();
        if (timeLeft <= 0) { return clearInterval(interval); }
        var particleCount = 50 * (timeLeft / duration);
        confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
        confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
      }, 250);
    }
  }

  const showToast = (icon, title) => Swal.fire({
    toast: true, position: 'top-end', showConfirmButton: false,
    timer: 3500, timerProgressBar: true, icon, title
  });

  document.getElementById('rzp-button').onclick = async function(e) {
    e.preventDefault();
    const amount = finalCalculatedTotal * 100;
    const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

    if (amount < 100) {
      showToast('warning', 'Amount must be at least Rs 1.');
      return;
    }

    if (paymentMethod === 'cod') {
      // Pass the current discount code to the COD form and submit
      document.getElementById('codDiscountCode').value = currentDiscountCode;
      document.getElementById('checkoutForm').submit();
      return;
    }

    // Online Payment Flow (Razorpay)
    try {
      const response = await fetch('/api/create-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount: amount, currency: 'INR', receipt: 'rcptid_11', discountCode: currentDiscountCode })
      });
      const order = await response.json();

      if(order.error) {
        showToast('error', 'Error: ' + order.error);
        return;
      }

      var options = {
        "key": "<%= locals.razorpay_key_id || '' %>", 
        "amount": order.amount,
        "currency": order.currency,
        "name": "The Cake Shop",
        "description": "Checkout Payment",
        "order_id": order.id,
        "handler": async function (response){
          const verifyRes = await fetch('/api/verify-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature
            })
          });
          const verifyData = await verifyRes.json();
          if(verifyData.success) {
            window.location.href = '/billing';
          } else {
            showToast('error', 'Payment verification failed!');
          }
        },
        "theme": { "color": "#d97706" }
      };
      var rzp1 = new Razorpay(options);
      rzp1.on('payment.failed', function (response){
        showToast('error', 'Payment failed: ' + response.error.description);
      });
      rzp1.open();
    } catch (err) {
      console.error(err);
      showToast('error', 'Something went wrong. Please try again.');
    }
  }
</script>

  <% } else { %>
    <div class="text-center">
      <p>Your cart is empty.</p>
      <a href="/" class="btn btn-primary">Continue Shopping</a>
    </div>
  <% } %>
</div>

<%- include('include/footer') %>